{
  "name": "temi-dev-monorepo",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:turbo": "turbo run dev --parallel -- --turbo",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test"
  },
  "devDependencies": {
    "turbo": "^2.1.1",
    "eslint": "^9.13.0",
    "typescript-eslint": "^8.13.0",
    "@eslint/js": "^9.13.0"
  }
}
