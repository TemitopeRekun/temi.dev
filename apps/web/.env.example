# ==========================================
# Web Environment Variables
# ==========================================

# API Connection
# The URL where your NestJS backend is running
NEXT_PUBLIC_API_BASE_URL="http://localhost:4000"

# Fallback API URL (often same as above)
NEXT_PUBLIC_API_URL="http://localhost:4000"

# Site Metadata
# The public URL of your portfolio (used for SEO, sitemaps, OG images)
NEXT_PUBLIC_SITE_URL="https://temi.dev"

# Visuals
# Path to your hero video in the public folder
NEXT_PUBLIC_HERO_VIDEO_URL="/hero.mp4"

# Debugging
# Set to "true" to enable bundle analysis
ANALYZE="false"
