# ==========================================
# Web Environment Variables
# ==========================================

# API Connection
# The URL where your NestJS backend is running
NEXT_PUBLIC_API_BASE_URL="http://localhost:4000"

# Server-only API base URL (not exposed to the browser). Preferred over
# NEXT_PUBLIC_API_BASE_URL for server-side proxy fetches when set.
API_BASE_URL="http://localhost:4000"

# Server-only secret used to verify the admin JWT signature in middleware
# (HS256). Must match the secret the NestJS API signs tokens with. When unset,
# middleware falls back to a cookie-presence check only (dev convenience).
JWT_SECRET=""

# Fallback API URL (often same as above)
NEXT_PUBLIC_API_URL="http://localhost:4000"

# Site Metadata
# The public URL of your portfolio (used for SEO canonicals, sitemaps, OG
# images). This is the single canonical host — keep it in sync with the API's
# CORS_ORIGINS.
NEXT_PUBLIC_SITE_URL="https://www.temitope.live"

# Visuals
# Path to your hero video in the public folder
NEXT_PUBLIC_HERO_VIDEO_URL="/hero.mp4"

# Debugging
# Set to "true" to enable bundle analysis
ANALYZE="false"
