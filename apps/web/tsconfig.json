{
  "extends": "../../packages/config/tsconfig/base.json",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@temi/ui": ["../../packages/ui/src"],
      "@temi/ui/*": ["../../packages/ui/src/*"]
    },
    "allowJs": false,
    "incremental": true,
    "jsx": "preserve",
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": ["app", "components", "next-env.d.ts", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
