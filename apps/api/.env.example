# Runtime environment. One of: development | test | production.
NODE_ENV="development"

# Pooled (pgbouncer) connection used at runtime. For Supabase append
# `?pgbouncer=true&connection_limit=1` to the pooled URL.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/temi_dev?schema=public"
# Direct (non-pooled) connection for `prisma migrate` / introspection. On
# Supabase this is the 5432 direct endpoint, not the 6543 pooler.
DIRECT_URL="postgresql://USER:PASSWORD@localhost:5432/temi_dev?schema=public"

# CORS — comma-separated browser-origin allowlist. Localhost is auto-allowed
# outside production. When unset, defaults to the canonical production domains.
CORS_ORIGINS="https://temitope.live,https://www.temitope.live"

# Email (Resend)
RESEND_API_KEY=""
EMAIL_FROM="Temitope <hello@temitope.live>"
# Inbox that receives an alert on each new contact-form lead. Can be any
# address (incl. a personal Gmail) — only EMAIL_FROM must be on a verified
# Resend domain. Falls back to ADMIN_EMAIL when unset.
LEAD_NOTIFY_EMAIL="olalekanogunrekun@gmail.com"

# Auth
# Must be at least 16 chars and NOT the literal "change_me" (boot validation).
JWT_SECRET="replace_with_a_long_random_secret"
ADMIN_EMAIL="admin@temitope.live"
# bcrypt hash of your admin password. New hashes are written at cost factor 12;
# this seed value can be generated with bcryptjs.
ADMIN_PASSWORD_HASH="$2a$12$replace_with_real_hash"

# AI (Gemini)
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
# Embedding model + dimension MUST match the vector(N) column in schema.prisma.
GEMINI_EMBEDDING_MODEL="gemini-embedding-001"
GEMINI_EMBEDDING_DIM="768"
# Cosine-similarity floor for RAG retrieval (0–1). Tuned for the model above.
RAG_SIMILARITY_FLOOR="0.5"

# Supabase Storage
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_BUCKET="uploads"

# Error monitoring (Sentry) — leave empty to disable
SENTRY_DSN=""
