# Pooled (pgbouncer) connection used at runtime. For Supabase append
# `?pgbouncer=true&connection_limit=1` to the pooled URL.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/temi_dev?schema=public"
# Direct (non-pooled) connection for `prisma migrate` / introspection. On
# Supabase this is the 5432 direct endpoint, not the 6543 pooler.
DIRECT_URL="postgresql://USER:PASSWORD@localhost:5432/temi_dev?schema=public"

# Email (Resend)
RESEND_API_KEY=""
EMAIL_FROM="Temitope <hello@temi.dev>"

# Auth
# Must be at least 16 chars and NOT the literal "change_me" (boot validation).
JWT_SECRET="replace_with_a_long_random_secret"
ADMIN_EMAIL="admin@temi.dev"
# bcrypt hash of your admin password (e.g., using bcryptjs with 10 salt rounds)
ADMIN_PASSWORD_HASH="$2a$10$replace_with_real_hash"

# AI (Gemini)
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
GEMINI_EMBEDDING_MODEL="text-embedding-005"

# Supabase Storage
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_BUCKET="uploads"

# Error monitoring (Sentry) — leave empty to disable
SENTRY_DSN=""
