{
  "extends": "../config/tsconfig/base.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": false,
    "emitDeclarationOnly": false,
    // Emit CommonJS (this package has no "type":"module", so Node16 module
    // resolves to CJS output) so the CommonJS NestJS API can `require()` the
    // shared runtime constants at runtime.
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "dist",
    "rootDir": "src"
  },
  "include": ["src"]
}
