{
  "extends": "../config/tsconfig/base.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": false,
    "emitDeclarationOnly": false,
    // Emit CommonJS (no "type":"module" → Node16 module resolves to CJS output)
    // so the CommonJS NestJS API can `require()` the built prompts at runtime.
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "dist",
    "rootDir": "src"
  },
  "include": ["src"]
}
